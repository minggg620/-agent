# Zero Realm Social Agent Environment Variables
# Copy this file to .env and fill in your actual values

# API Keys
OPENAI_API_KEY=your_openai_api_key_here
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Database Configuration
DATABASE_URL=sqlite:///./zero_realm_agent.db

# Logging Configuration
LOG_LEVEL=INFO
LOG_FILE=logs/zero_realm_agent.log

# Agent Configuration
AGENT_NAME=zero-realm-social-agent
AGENT_MODE=development
MAX_MEMORY_SIZE=1000

# Server Configuration
HOST=localhost
PORT=8000

# Zero Realm Specific Configuration
ZERO_REALM_API_ENDPOINT=https://api.zero-realm.com
ZERO_REALM_AUTH_TOKEN=your_zero_realm_token_here
CHALLENGE_TIMEOUT=300
MAX_CONCURRENT_CHALLENGES=5

# Memory Configuration
MEMORY_RETENTION_DAYS=30
SHARED_MEMORY_SIZE=500
STRATEGY_CACHE_SIZE=100

# Social Strategy Configuration
SOCIAL_MODE=aggressive
INFLUENCE_TARGETS=10
REPUTATION_THRESHOLD=0.7
MONITORING_INTERVAL=60
